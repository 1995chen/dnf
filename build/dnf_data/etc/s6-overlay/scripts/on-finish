#!/bin/bash

# s6-supervise 调用时会传四个参数:
# $1: exit_code, $2: 信号编号, $3: 服务名, $4: 进程组 ID
# 返回 125 让 s6-supervise 视为正常退出无需重启, 其他返回值会触发重启。

notify_target="${DNF_SVC_NOTIFY_TARGET:-/proc/1/fd/1}"

notify() { (echo "$@" >"$notify_target") 2>/dev/null || true; }

svc="${3:-$PWD}"
svc="${svc##*/}"

if [ "$1" = 0 ]; then
    notify "[svc] ${svc} stopped (exit 0)"
    exit 125
fi

if [ "$1" = 256 ]; then
    # 进程组 ID 为空或 0/1 时跳过, 否则 kill -9 -- -0/-1 会误杀当前进程组或全部进程
    case "$4" in
    '' | 0 | 1) ;;
    *) kill -9 -- "-$4" 2>/dev/null ;;
    esac
    sig="$2"
    signame=$(kill -l "$sig" 2>/dev/null || printf '%s' "$sig")

    # 将 IOT 统一为 ABRT
    [ "$signame" = IOT ] && signame=ABRT

    case "$sig" in
    4 | 6 | 7 | 8 | 11)
        # SIGILL/ABRT/BUS/FPE/SEGV: 进程崩溃
        notify "[svc] ${svc} crashed (SIG${signame})"
        ;;
    *)
        notify "[svc] ${svc} killed by SIG${signame}"
        ;;
    esac
else
    # 进程异常退出
    notify "[svc] ${svc} exited abnormally (code=${1})"
fi
