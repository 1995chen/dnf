# check=skip=SecretsUsedInArgOrEnv
ARG BASE_TAG=alma9-base

# 下载MySQL 5.7
FROM almalinux:9.7-minimal AS mysql-builder

RUN microdnf --setopt=install_weak_deps=0 install -y curl-minimal ca-certificates tar gzip binutils epel-release \
    && microdnf --setopt=install_weak_deps=0 install -y jemalloc \
    && microdnf clean all

RUN MYSQL=mysql-5.7.44-linux-glibc2.12-x86_64 && \
    cd /tmp && \
    curl -fsSLO https://downloads.mysql.com/archives/get/p/23/file/${MYSQL}.tar.gz && \
    tar -zxf ${MYSQL}.tar.gz && \
    mkdir -p /mysql/bin /mysql/lib /mysql/share /mysql/allocator && \
    cp ${MYSQL}/bin/mysql ${MYSQL}/bin/mysqld ${MYSQL}/bin/mysqld_safe \
       ${MYSQL}/bin/mysqladmin ${MYSQL}/bin/mysqldump ${MYSQL}/bin/my_print_defaults \
       ${MYSQL}/bin/mysql_ssl_rsa_setup ${MYSQL}/bin/resolveip /mysql/bin/ && \
    strip /mysql/bin/mysql /mysql/bin/mysqld /mysql/bin/mysqladmin \
          /mysql/bin/mysqldump /mysql/bin/my_print_defaults \
          /mysql/bin/mysql_ssl_rsa_setup /mysql/bin/resolveip && \
    cp -a ${MYSQL}/lib/*.so* /mysql/lib/ && \
    strip --strip-unneeded /mysql/lib/*.so* && \
    cp -L /usr/lib64/libjemalloc.so.2 /mysql/allocator/libjemalloc.so.2 && \
    strip --strip-unneeded /mysql/allocator/libjemalloc.so.2 && \
    cp -r ${MYSQL}/share/english ${MYSQL}/share/charsets /mysql/share/ && \
    (cp ${MYSQL}/share/*.sql ${MYSQL}/share/errmsg-utf8.txt /mysql/share/ 2>/dev/null; true) && \
    rm -rf /tmp/*

FROM llnut/dnf:${BASE_TAG}

ENV DNF_DB_ROOT_PASSWORD=88888888 \
    PATH="/usr/local/mysql/bin:${PATH}" \
    AUTO_TUNE=true \
    TUNE_PROFILE='' \
    TUNE_VERBOSE=false

COPY --from=mysql-builder /mysql/bin/ /usr/local/mysql/bin/
COPY --from=mysql-builder /mysql/lib/ /usr/local/mysql/lib/
COPY --from=mysql-builder /mysql/share/ /usr/local/mysql/share/
COPY --from=mysql-builder /mysql/allocator/libjemalloc.so.2 /usr/lib/libjemalloc.so.2

# 安装MySQL 5.7依赖
RUN microdnf install -y \
    libaio numactl-libs libxcrypt-compat \
    && groupadd mysql && useradd -r -g mysql -s /bin/false mysql \
    && mkdir -p /var/lib/mysql /var/run/mysqld /var/log/mysql \
    && chown -R mysql:mysql /var/lib/mysql /var/run/mysqld /var/log/mysql \
    && chmod 750 /var/lib/mysql /var/run/mysqld \
    && microdnf clean all

# MySQL符号链接和初始化脚本
RUN for bin in mysql mysqld_safe mysqladmin mysqldump my_print_defaults; do \
        ln -sf /usr/local/mysql/bin/$bin /usr/bin/$bin; \
    done \
    && ln -sf /usr/local/mysql/bin/mysqld /usr/sbin/mysqld \
    && echo '/usr/local/mysql/lib' > /etc/ld.so.conf.d/mysql.conf && ldconfig \
    && rm -rf /tmp/* /var/tmp/*

COPY --chmod=0755 build/shared/service-wrapper.sh /usr/sbin/service
COPY --chmod=0755 build/shared/mysql-install-db.sh /usr/bin/mysql_install_db
COPY --chmod=0755 build/shared/mysql-initd.sh /etc/init.d/mysql

COPY build/dnf_data/home/template/init/lib/common.sh /home/template/init/lib/common.sh
COPY build/dnf_data/home/template/init/lib/tune.sh /home/template/init/lib/tune.sh

COPY build/dnf_data/etc/my.cnf /etc/

COPY --chmod=0755 build/shared/docker-entrypoint-db.sh /docker-entrypoint.sh

VOLUME /var/lib/mysql
EXPOSE 4000
CMD ["/bin/bash", "/docker-entrypoint.sh"]
